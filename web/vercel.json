{
  "redirects": [
    {
      "source": "/:path(.*)",
      "has": [
        {
          "type": "host",
          "value": "learn-real-claude-agent.vercel.app"
        }
      ],
      "destination": "https://learn.ownlab.app/:path",
      "permanent": true
    },
    {
      "source": "/en",
      "destination": "/en/",
      "permanent": false
    },
    {
      "source": "/",
      "destination": "/en/",
      "permanent": false
    }
  ]
}
